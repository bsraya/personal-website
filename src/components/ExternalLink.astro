---
import ExternalLinkIcon from "@component/ExternalLinkIcon.astro";
const { url, text, ariaLabel } = Astro.props;

const label = ariaLabel ?? `${text} (opens in new tab)`;
---

<a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="cursor-pointer"
    aria-label={label}
>
    <span class="underline">{text}</span><ExternalLinkIcon />
</a>