---
import BaseLayout from "@layout/BaseLayout.astro";
import Heading from "@component/Heading.astro";

const pageTitle = "Resume";
const pageDescription = "Bijon Setyawan Raya's professional resume.";

const experience = [
  {
    title: "Machine Learning Engineer",
    company: "IKG Team Ltd.",
    location: "Taipei, Taiwan",
    period: "October 2025 - Present",
    descriptions: [
        "Designed and shipped a content moderation system from scratch, replacing an LLM-based PoC with a Go-based embedding + reranker pipeline — reducing response time by 99% (8s to ~785ms) and reducing inference costs by 99% (100k to <1k tokens)",
        "Built a precomputed financial metrics layer using tiered data architecture (Bronze/Silver/Gold), reducing 70% avg. query time (10s+ to <3s)",
        "Architected and deployed the first automated data pipeline on all environments, transforming raw source data into governed financial metrics at 1M+ records/day — maintaining 99.9% SLA"
    ],
  },
  {
    title: "Machine Learning Engineer",
    company: "Cathay United Bank",
    location: "Taipei, Taiwan",
    period: "November 2024 - October 2025",
    descriptions: [
        "Architected a 3-tier content safety system, reducing response time from 50s+ to under 5s while blocking 99% of unsafe interactions",
        "Prototyped a no-code MLOps pipeline enabling scientists to train, validate, and deploy scikit-learn models, cut training time 5× with cuML and automated model deployment for real-time inference"
    ],
  },
  {
    title: "Fullstack Developer",
    company: "Faria Education Group",
    location: "Taipei, Taiwan",
    period: "October 2022 - March 2024",
    descriptions: [
        "Migrated 25% of legacy CoffeeScript codebase to Stimulus.js, cutting build times by 40%",
        "Optimized file export pipeline, reducing export times from 5+ minutes to under 3 seconds (99% faster)"
    ],
  },
];

const skills = [
  {
    category: "Programming Languages",
    items: ["C/C++", "Golang", "Python", "SQL", "Zig"],
  },
  {
    category: "Deep Learning & Machine Learning",
    items: ["CUDA", "HIP/ROCm", "MLflow", "cuML", "PyTorch", "Scikit-learn"],
  },
  {
    category: "Data Engineering",
    items: ["Apache Airflow", "Apache Iceberg", "dbt", "DuckDB", "MongoDB", "PostgreSQL", "SQLite", "Redis", "Qdrant"],
  },
  {
    category: "Systems & Infrastructure",
    items: ["Docker", "Git", "Kubernetes", "Terraform", "Linux/Unix", "Podman"],
  },
  {
    category: "Cloud Services",
    items: ["Amazon Web Services", "Google Cloud Platform"],
  },
];

const education = [
  {
    degree: "Master of Science in Computer Science",
    institution: "National Tsing Hua University",
    year: "January 2023",
  },
  {
    degree: "Bachelor of Science in Computer Science",
    institution: "National Tsing Hua University",
    year: "January 2021",
  },
];
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
    <div class="grid divide-y divide-slate-200">
        <!-- Experience -->
        <section class="flex flex-col gap-5 pb-6">
            <Heading as="h2" size="xl" class="mb-2">Experience</Heading>
            <div class="grid gap-8">
                {experience.map((job) => (
                    <div>
                        <Heading as="h3" size="xl" weight="bold">{job.title}</Heading>
                        <p class="text-base italic">{job.company} — {job.location}</p>
                        <time class="text-sm text-text-subtle">{job.period}</time>
                        {
                            job.descriptions.length > 0 && (
                                <ul class="list-disc pl-5 mt-1">
                                    {
                                        job.descriptions.map((d) => (
                                            <li>{d}</li>
                                        ))
                                    }
                                </ul>
                            )
                        }
                    </div>
                ))}
            </div>
        </section>

        <!-- Education -->
        <section class="pt-6 pb-6">
            <Heading as="h2" size="xl" class="mb-2">Education</Heading>
            <div class="grid gap-8">
                {education.map((edu) => (
                <div>
                    <Heading as="h3" size="md" weight="bold">{edu.institution}</Heading>
                    <p class="text-base italic">{edu.degree}</p>
                    <time class="text-sm text-text-subtle">{edu.year}</time>
                </div>
                ))}
            </div>
        </section>

        <!-- Technical Skills -->
        <section class="flex flex-col gap-5 pt-6">
            <Heading as="h2" size="xl" class="mb-2">Technical Skills</Heading>
            <div class="grid gap-8">
                {
                    skills.map((skill) => (
                        <div>
                            <Heading as="h3" size="md" weight="bold">{skill.category}</Heading>
                            <div class="flex flex-wrap gap-1.5 mt-1">
                                {skill.items.map((item) => (
                                    <span class="border border-border rounded-md text-xs px-2 py-0.5 text-text-subtle">{item}</span>
                                ))}
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>
    </div>
</BaseLayout>
