---
export const prerender = true;
import ContentCard from "@component/ContentCard.astro";
import BaseLayout from "@layout/BaseLayout.astro";
import Heading from "@component/Heading.astro";

import { ArrowLeft } from "@lucide/astro";

import { slugify, deslugify } from "@lib/string";
import { getAllPosts, getPostsByTag } from "@lib/content";

export async function getStaticPaths() {
  const tags = new Set<string>();
  const posts = await getAllPosts();

  for (const post of posts) {
    if (post.data.tag) {
      tags.add(slugify(post.data.tag));
    }
  }

  return Array.from(tags).map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
const pageTitle = `${deslugify(tag)} posts`;
const pageDescription = `${deslugify(tag)} posts written by ${import.meta.env.AUTHOR}.`;
const allPosts = await getPostsByTag(tag);
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
  <a href="/posts" class="w-fit flex items-center gap-1 group" aria-label="Back to all posts">
      <ArrowLeft size={14} class="group-hover:-translate-x-1 transition-transform duration-150" />
      <span>All posts</span>
  </a>
  <Heading as="h1" size="lg" class="mt-5 mb-6 text-text-subtle">
    Posts tagged with <span class="font-bold underline">{deslugify(tag)}</span>
  </Heading>
  <div class="grid grid-col gap-8 mb-5">
    {
      allPosts.map((post) => (
        <ContentCard
          path={post.id}
          frontmatter={post.data}
          type="posts"
        />
      ))
    }
  </div>
</BaseLayout>
