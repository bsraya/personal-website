---
import BaseLayout from "@layout/BaseLayout.astro";
import ContentCard from "@component/ContentCard.astro";
import ExternalLink from "@component/ExternalLink.astro";
import Heading from "@component/Heading.astro";
import { getSortedPosts, getSortedWorks } from "@lib/content";
import { ArrowRight } from "@lucide/astro";

const siteUrl = "https://www.bijonsetyawan.com";
const pageTitle = "Home";
const pageDescription = "I make machines learn, and I write about it";
const keywords = [
  "machine learning",
  "deep learning",
  "data science",
  "software engineering",
  "blog",
  "personal website",
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Bijon Setyawan Raya",
  url: siteUrl,
  sameAs: ["https://github.com/bsraya"],
  jobTitle: "Software Engineer",
  knowsAbout: [
    "Machine Learning",
    "Deep Learning",
    "Data Science",
    "Software Engineering",
  ],
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Bijon Setyawan Raya",
  url: siteUrl,
  description: pageDescription,
  author: { "@type": "Person", name: "Bijon Setyawan Raya", url: siteUrl },
};

const posts = getSortedPosts().slice(0, 3);
const works = getSortedWorks().slice(0, 3);
---

<BaseLayout
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  keywords={keywords}
  schema={[personSchema, webSiteSchema]}
>
  <div class="grid grid-col gap-20">
    <div class="grid grid-col">
      <Heading as="h2" size="2xl">Bijon Setyawan Raya</Heading>
      <div class="text-slate-600 text-lg">{pageDescription}</div>
      <div>
        Get my <ExternalLink
          text="resume"
          url="/resume.pdf"
          ariaLabel="Download Bijon Setyawan Raya's resume (PDF)"
        />
      </div>
    </div>

    <div>
      <Heading as="h2" size="lg" class="mb-2">Selected Works</Heading>
      <div class="grid grid-col gap-8 mb-5">
        {
          works.map((work) => (
            <ContentCard
              path={work.url}
              frontmatter={work.frontmatter}
              type="works"
            />
          ))
        }
      </div>
      <a aria-label="View all works" href="/works" class="w-fit flex items-center gap-1 hover:gap-2 transition-gap duration-150">
        <span>See more</span><ArrowRight size={14} />
      </a>
    </div>

    <div>
      <Heading as="h2" size="lg" class="mb-2">Latest Posts</Heading>
      <div class="grid grid-col gap-8 mb-5">
        {
          posts.map((post) => (
            <ContentCard
              path={post.url}
              frontmatter={post.frontmatter}
              type="posts"
            />
          ))
        }
      </div>
      <a aria-label="View all blog posts" href="/posts" class="w-fit flex items-center gap-1 hover:gap-2 transition-gap duration-150">
        <span>See more</span><ArrowRight size={14} />
      </a>
    </div>
  </div>
</BaseLayout>
